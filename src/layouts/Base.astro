---
import type { Translation } from '../data/translations';
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
  tr: Translation;
  title?: string;
  desc?: string;
  ogImage?: string;
  canonical?: string;
  jsonLd?: object;
  simple?: boolean;
}

const {
  tr,
  title = tr.metaTitle,
  desc = tr.metaDesc,
  ogImage = tr.ogImage,
  canonical,
  jsonLd,
  simple = false,
} = Astro.props;

const isRTL = tr.dir === 'rtl';
const canon = canonical ?? `https://laregularizacion.com${Astro.url.pathname}`;
const arabicFont = tr.lang === 'ar';
const urduFont = tr.lang === 'ur';

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'LaRegularizacion.com',
  url: 'https://laregularizacion.com',
  description: 'Guía independiente no oficial sobre la Regularización Extraordinaria España 2026',
  inLanguage: [tr.htmlLang],
};

const formLinks: Record<string, string> = {
  ex31: 'https://www.inclusion.gob.es/regularizacion',
  ex32: 'https://www.inclusion.gob.es/regularizacion',
  vuln: 'https://www.inclusion.gob.es/regularizacion',
  boe:  'https://www.boe.es/boe/dias/2026/04/15/pdfs/BOE-A-2026-8284.pdf',
  tasa: 'https://sede.agenciatributaria.gob.es/Sede/procedimientoini/GI01.shtml',
  faq:  'https://www.inclusion.gob.es/regularizacion',
};
---

<!DOCTYPE html>
<html lang={tr.htmlLang} dir={tr.dir}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={desc} />
  <meta name="keywords" content={tr.keywords} />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <link rel="canonical" href={canon} />

  <!-- hreflang -->
  <link rel="alternate" hreflang="es" href="https://laregularizacion.com/" />
  <link rel="alternate" hreflang="en" href="https://laregularizacion.com/en/" />
  <link rel="alternate" hreflang="ar" href="https://laregularizacion.com/ar/" />
  <link rel="alternate" hreflang="ur" href="https://laregularizacion.com/ur/" />
  <link rel="alternate" hreflang="x-default" href="https://laregularizacion.com/" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={desc} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canon} />
  <meta property="og:site_name" content="LaRegularizacion.com" />
  <meta property="og:locale" content={tr.htmlLang} />

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2691466441263858" crossorigin="anonymous"></script>

  <!-- Analytics removed -->

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={desc} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts: one request for all languages -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=DM+Mono:wght@400;500&family=Noto+Kufi+Arabic:wght@400;500;600;700&family=Noto+Nastaliq+Urdu:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd ?? defaultJsonLd)} />

  <!-- Favicon (SVG) -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📋</text></svg>" />
</head>

<body>

  {!simple && (
  <!-- ══ DISCLAIMER (always at top) ══ -->
  <div class="bg-amber-50 border-b border-amber-200/80">
    <div class="max-w-6xl mx-auto px-4 py-1.5">
      <p class:list={['text-center text-xs text-amber-800 leading-snug', isRTL ? 'font-arabic' : 'font-mono']}>
        {tr.unofficial} ·
        {tr.lang === 'es' && <span>Fuente oficial: </span>}
        {tr.lang === 'en' && <span>Official source: </span>}
        {tr.lang === 'ar' && <span>المصدر الرسمي: </span>}
        {tr.lang === 'ur' && <span>سرکاری ذریعہ: </span>}
        <a href="https://www.inclusion.gob.es/regularizacion" target="_blank" rel="noopener"
           class="font-semibold underline text-amber-900 hover:text-amber-700 transition-colors">
          inclusion.gob.es/regularizacion
        </a>
      </p>
    </div>
  </div>

  )}

  {!simple && (
  <Header tr={tr} />
  )}


  <!-- ══ CONTENT ══ -->
  <main>
    <slot />
  </main>

  {!simple && (
  <!-- ══ FOOTER ══ -->
  <footer class="bg-slate-900 text-slate-300 mt-20 border-t-4 border-blue-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">

      <!-- Disclaimer box — prominent -->
      <div class:list={[
        'rounded-2xl border border-amber-600/30 bg-amber-900/20 p-5 mb-10 text-sm leading-relaxed',
        isRTL ? 'text-right font-arabic' : 'text-left font-body'
      ]}>
        <span class="text-amber-400 font-bold">⚠️ </span>
        <span class="text-amber-200">{tr.footer.disclaimer}</span>
      </div>

      <!-- Footer grid: RTL reverses column order so brand is on the right -->
      <div class:list={['grid grid-cols-1 md:grid-cols-4 gap-8 mb-8', isRTL ? 'text-right md:grid-flow-col-dense' : '']}>

        <!-- Brand -->
        <div>
          <div class:list={['flex items-center gap-2.5 mb-3', isRTL ? 'flex-row-reverse justify-end' : '']}>
            <div class="w-7 h-7 rounded-lg bg-blue-700 flex items-center justify-center flex-shrink-0">
              <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414A1 1 0 0119 7.414V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <span class:list={['font-bold text-white text-base', isRTL ? 'font-arabic' : 'font-display']}>{tr.siteName}</span>
          </div>
          <p class:list={['text-xs text-slate-500 leading-relaxed', isRTL ? 'font-arabic' : 'font-mono']}>
            {tr.tagline}
          </p>
        </div>

        <!-- Official links -->
        <div>
          <h3 class:list={['font-mono text-xs text-slate-500 uppercase tracking-widest mb-3', isRTL ? 'font-arabic text-right' : '']}>
            {tr.footer.linksTitle}
          </h3>
          <ul class:list={['space-y-2', isRTL ? 'text-right' : '']}>
            {[
              { href: 'https://www.inclusion.gob.es/regularizacion', label: 'inclusion.gob.es/regularizacion' },
              { href: 'https://www.boe.es/boe/dias/2026/04/15/pdfs/BOE-A-2026-8284.pdf', label: 'BOE-A-2026-8284 (PDF)' },
              { href: 'tel:060', label: '📞 060' },
              { href: 'https://www.inclusion.gob.es/formulario-consultas-regularizacion-extraordinaria-2026', label: 'Formulario consultas' },
            ].map(l => (
              <li>
                <a href={l.href} target="_blank" rel="noopener"
                   class:list={['text-sm text-slate-400 hover:text-blue-400 transition-colors', isRTL ? 'font-arabic' : 'font-body']}
                   style="text-decoration:none">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal pages -->
        <div>
          <h3 class:list={['font-mono text-xs text-slate-500 uppercase tracking-widest mb-3', isRTL ? 'font-arabic text-right' : '']}>
            Legal
          </h3>
          <ul class:list={['space-y-2', isRTL ? 'text-right' : '']}>
            {[
              { 
                href: tr.lang === 'es' ? '/privacy' : `/${tr.lang}/privacy`,
                label: tr.lang === 'es' ? 'Política de Privacidad' : tr.lang === 'en' ? 'Privacy Policy' : tr.lang === 'ar' ? 'سياسة الخصوصية' : 'رازداری کی پالیسی'
              },
              { 
                href: tr.lang === 'es' ? '/terms' : `/${tr.lang}/terms`,
                label: tr.lang === 'es' ? 'Términos de Servicio' : tr.lang === 'en' ? 'Terms of Service' : tr.lang === 'ar' ? 'شروط الخدمة' : 'سروس کی شرائط'
              },
              { 
                href: tr.lang === 'es' ? '/disclaimer' : `/${tr.lang}/disclaimer`,
                label: tr.lang === 'es' ? 'Aviso Legal' : tr.lang === 'en' ? 'Legal Disclaimer' : tr.lang === 'ar' ? 'إخلاء المسؤولية' : 'قانونی ذمہ داری سے انکار'
              },
              { 
                href: tr.lang === 'es' ? '/about' : `/${tr.lang}/about`,
                label: tr.lang === 'es' ? 'Sobre Nosotros' : tr.lang === 'en' ? 'About Us' : tr.lang === 'ar' ? 'من نحن' : 'ہمارے بارے میں'
              },
              { 
                href: tr.lang === 'es' ? '/contact' : `/${tr.lang}/contact`,
                label: tr.lang === 'es' ? 'Contacto' : tr.lang === 'en' ? 'Contact' : tr.lang === 'ar' ? 'اتصل بنا' : 'رابطہ'
              },
            ].map(l => (
              <li>
                <a href={l.href}
                   class:list={['text-sm text-slate-400 hover:text-blue-400 transition-colors', isRTL ? 'font-arabic' : 'font-body']}
                   style="text-decoration:none">
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Languages -->
        <div>
          <h3 class:list={['font-mono text-xs text-slate-500 uppercase tracking-widest mb-3', isRTL ? 'font-arabic text-right' : '']}>
            {tr.footer.langsTitle}
          </h3>
          <div class:list={['flex flex-wrap gap-2', isRTL ? 'justify-end' : '']}>
            {[
              { code: 'es', label: 'Español', href: '/' },
              { code: 'en', label: 'English', href: '/en/' },
              { code: 'ar', label: 'العربية', href: '/ar/' },
              { code: 'ur', label: 'اردو',    href: '/ur/' },
            ].map(l => (
              <a href={l.href}
                 class:list={[
                   'px-3 py-1.5 rounded-lg text-xs font-medium transition-all',
                   tr.lang === l.code ? 'bg-blue-700 text-white' : 'bg-slate-800 text-slate-400 hover:bg-slate-700 hover:text-white'
                 ]}
                 style="text-decoration:none"
                 hreflang={l.code}
              >{l.label}</a>
            ))}
          </div>
        </div>
      </div>

      <div class="border-t border-slate-800 pt-6 text-center">
        <p class:list={['text-xs text-slate-600 leading-relaxed', isRTL ? 'font-arabic' : 'font-body']}>
          {tr.footer.note}
        </p>
      </div>
    </div>
  </footer>
  )}

</body>
</html>
<!-- Deployment trigger for AdSense verification -->
