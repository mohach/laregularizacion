---
import '../styles/global.css';
const {
  title = 'La Regularización',
  description = 'Información actualizada sobre la Regularización Extraordinaria de Extranjeros en España 2026',
} = Astro.props;

const navLinks = [
  { href: '/',             label: 'Inicio',       labelAr: 'الرئيسية' },
  { href: '/noticias',    label: 'Noticias',      labelAr: 'أخبار' },
  { href: '/guia',        label: 'Guía',          labelAr: 'دليل' },
  { href: '/requisitos',  label: 'Requisitos',    labelAr: 'الشروط' },
  { href: '/formularios', label: 'Formularios',   labelAr: 'الاستمارات' },
];
---

<!DOCTYPE html>
<html lang="es" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta name="theme-color" content="#c0392b" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title} | LaRegularizacion.es</title>
</head>
<body>

<!-- TOP BAR -->
<div class="top-bar">
  <div class="container">
    <div class="inner">
      <div class="ticker">
        <span>🔴 ÚLTIMA HORA: Plazo abierto hasta el 30 de junio de 2026 — الموعد النهائي: 30 يونيو 2026 — +500.000 personas — Vías DT5 y DT6 — بدون موعد مسبق</span>
      </div>
      <div class="date-lang">
        <button class="lang-btn active" id="btn-es" onclick="setLang('es')">ES</button>
        <button class="lang-btn" id="btn-ar" onclick="setLang('ar')">AR</button>
      </div>
    </div>
  </div>
</div>

<!-- MASTHEAD -->
<header class="masthead">
  <div class="inner">
    <a href="/" class="logo-name">La <span>Regularización</span></a>
    <div class="tagline">
      Información independiente · España 2026 · معلومات مستقلة
    </div>
  </div>
</header>

<!-- NAV -->
<nav class="main-nav" id="main-nav">
  <div class="nav-toggle">
    <span class="nav-toggle-label" id="nav-label">Menú</span>
    <button class="hamburger" id="hamburger" onclick="toggleNav()" aria-label="Menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav-links" id="nav-links">
    {navLinks.map(link => (
      <a
        href={link.href}
        data-label-es={link.label}
        data-label-ar={link.labelAr}
        class={Astro.url.pathname === link.href || Astro.url.pathname === link.href + '/' ? 'active' : ''}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<main><slot /></main>

<!-- FOOTER -->
<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <h4>LaRegularizacion.es</h4>
        <p>Portal independiente sobre la Regularización Extraordinaria 2026 (RD 316/2026). No afiliado al gobierno español.</p>
        <p class="ar" style="font-size:.78rem;color:#888;margin-top:.5rem">بوابة مستقلة حول التسوية الاستثنائية في إسبانيا 2026.</p>
        <p class="disclaimer">No somos el gobierno. Siempre consulte inclusion.gob.es y boe.es.</p>
      </div>
      <div>
        <h4>Fuentes Oficiales</h4>
        <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.35rem">
          <li><a href="https://www.inclusion.gob.es" target="_blank" rel="noopener">Ministerio de Inclusión</a></li>
          <li><a href="https://www.boe.es" target="_blank" rel="noopener">BOE — RD 316/2026</a></li>
          <li><a href="https://extranjeros.inclusion.gob.es" target="_blank" rel="noopener">Extranjeros.gob.es</a></li>
          <li><a href="https://sede.administracionespublicas.gob.es" target="_blank" rel="noopener">Sede Electrónica</a></li>
        </ul>
      </div>
      <div>
        <h4>Secciones</h4>
        <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:.35rem">
          {navLinks.map(link => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>
    </div>
    <div class="bottom">
      <span>© 2026 LaRegularizacion.es — Información independiente</span>
      <span>No es sitio oficial del gobierno</span>
    </div>
  </div>
</footer>

<script is:inline>
function toggleNav() {
  const nl = document.getElementById('nav-links');
  const hb = document.getElementById('hamburger');
  const open = nl.classList.toggle('open');
  hb.classList.toggle('open', open);
  hb.setAttribute('aria-expanded', open);
}
document.querySelectorAll('.nav-links a').forEach(a => {
  a.addEventListener('click', () => {
    document.getElementById('nav-links').classList.remove('open');
    document.getElementById('hamburger').classList.remove('open');
  });
});

function setLang(lang) {
  document.documentElement.lang = lang;
  document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
  document.getElementById('btn-es').classList.toggle('active', lang === 'es');
  document.getElementById('btn-ar').classList.toggle('active', lang === 'ar');
  document.querySelectorAll('.nav-links a[data-label-ar]').forEach(a => {
    a.textContent = lang === 'ar' ? a.dataset.labelAr : a.dataset.labelEs;
  });
  const nl = document.getElementById('nav-label');
  if (nl) nl.textContent = lang === 'ar' ? 'القائمة' : 'Menú';
  document.querySelectorAll('[data-lang]').forEach(el => {
    el.style.display = el.dataset.lang === lang ? '' : 'none';
  });
  localStorage.setItem('preferred-lang', lang);
}
const saved = localStorage.getItem('preferred-lang');
if (saved && saved !== 'es') setLang(saved);
</script>
</body>
</html>
