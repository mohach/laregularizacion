---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../data/translations';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';
import matter from 'gray-matter';

const tr = t('ur');

let posts = [];
try {
  const blogDir = join(process.cwd(), 'src', 'content', 'blog');
  const files = await readdir(blogDir);
  for (const file of files.filter(f => f.endsWith('.mdx'))) {
    const raw = await readFile(join(blogDir, file), 'utf8');
    const { data } = matter(raw);
    if (data.title_ur) posts.push({ 
      ...data, 
      file: file.replace('.mdx', ''),
      title: data.title_ur,
      excerpt: data.excerpt_ur
    });
  }
  posts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
} catch (e) { console.log('Blog dir not ready:', e.message); }
---

<Base tr={tr} title={`خبریں — ${tr.metaTitle}`} desc={tr.blog.desc}>
  <section class="py-16 bg-slate-50 min-h-screen">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">

      <div class="mb-10">
        <h1 class="font-display text-3xl font-bold text-slate-900 mb-2">{tr.blog.title}</h1>
        <p class="font-body text-sm text-slate-500 italic">{tr.blog.desc}</p>
      </div>

      {posts.length === 0 ? (
        <div class="bg-white rounded-2xl border border-slate-200 p-8 text-center">
          <div class="text-4xl mb-3">🤖</div>
          <p class="font-body text-slate-500">{tr.blog.noArticles}</p>
        </div>
      ) : (
        <div class="space-y-6">
          {posts.map(post => (
            <article class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-lg hover:-translate-y-0.5 transition-all group">
              {/* Image */}
              {post.image && (
                <a href={`/ur/blog/${post.file}`}>
                  <div class="w-full h-48 overflow-hidden">
                    <img
                      src={post.image}
                      alt={post.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                </a>
              )}

              <div class="p-6">
                <div class="flex items-center gap-2 mb-3">
                  <time class="font-mono text-xs text-slate-500 bg-slate-100 px-2 py-1 rounded">
                    {new Date(post.date).toLocaleDateString('ur-PK', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  {post.category && (
                    <span class="font-mono text-xs text-slate-500 bg-slate-100 px-2 py-1 rounded">
                      {post.category}
                    </span>
                  )}
                  {post.is_trending && (
                    <span class="font-mono text-xs text-amber-700 bg-amber-100 px-2 py-1 rounded">
                      {tr.blog.trendingTag}
                    </span>
                  )}
                </div>

                <h2 class="font-display text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-700 transition-colors">
                  <a href={`/ur/blog/${post.file}`}>{post.title}</a>
                </h2>

                <p class="font-body text-slate-600 mb-4">{post.excerpt}</p>

                <div class="flex items-center justify-between">
                  <a
                    href={`/ur/blog/${post.file}`}
                    class="font-display text-sm font-semibold text-blue-700 hover:text-blue-800 flex items-center gap-1"
                  >
                    {tr.blog.readMore} ←
                  </a>
                  {post.sources && post.sources.length > 0 && (
                    <span class="font-mono text-xs text-slate-400">
                      {tr.blog.sourceLabel} {post.sources.length}
                    </span>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>