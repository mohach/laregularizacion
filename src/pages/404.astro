---
import Base from '../layouts/Base.astro';
---

<Base title="Página no encontrada">
  <div class="container" style="padding:6rem 0;text-align:center">
    <div style="font-family:var(--font-display);font-size:8rem;font-weight:900;color:var(--border);line-height:1">404</div>
    <h1 style="font-size:2rem;margin:1rem 0 0.75rem" data-lang="es">Página no encontrada</h1>
    <h1 style="font-size:2rem;margin:1rem 0 0.75rem;font-family:'Noto Naskh Arabic','Scheherazade New',serif;display:none" data-lang="ar">الصفحة غير موجودة</h1>
    <p style="color:var(--ink-2);margin-bottom:2rem" data-lang="es">La página que buscas no existe o ha sido movida.</p>
    <p style="color:var(--ink-2);margin-bottom:2rem;font-family:'Noto Naskh Arabic','Scheherazade New',serif;display:none" data-lang="ar">الصفحة التي تبحث عنها غير موجودة.</p>
    <a href="/" style="background:var(--red);color:white;padding:0.85rem 2rem;font-family:var(--font-ui);font-size:0.82rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;border-radius:2px;display:inline-block" data-lang="es">← Volver al inicio</a>
    <a href="/" style="background:var(--red);color:white;padding:0.85rem 2rem;font-family:'Noto Naskh Arabic','Scheherazade New',serif;font-size:0.9rem;font-weight:700;border-radius:2px;display:none" data-lang="ar">العودة للرئيسية ←</a>
  </div>
</Base>
