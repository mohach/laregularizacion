---
import Base from "../../../layouts/Base.astro";;
import { t } from '../../../data/translations';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';
import matter from 'gray-matter';

export async function getStaticPaths() {
  const blogDir = join(process.cwd(), 'src', 'content', 'blog');
  try {
    const files = await readdir(blogDir);
    return files
      .filter(f => f.endsWith('.mdx'))
      .map(f => ({ params: { slug: f.replace('.mdx', '') } }));
  } catch { return []; }
}

const { slug } = Astro.params;
const tr = t('en');

let post: any = null;
try {
  const blogDir = join(process.cwd(), 'src', 'content', 'blog');
  const raw = await readFile(join(blogDir, `${slug}.mdx`), 'utf8');
  const { data } = matter(raw);
  post = {
    ...data,
    title: data.title_en,
    excerpt: data.excerpt_en,
    body: data.body_en
  };
} catch (e) {
  console.error('Post not found:', slug);
}

// Simple markdown-to-HTML renderer (no heavy deps needed)
function renderMd(md: string): string {
  if (!md) return '';
  return md
    .replace(/^#{2}\s+(.+)$/gm, '<h2>$1</h2>')
    .replace(/^#{3}\s+(.+)$/gm, '<h3>$1</h3>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
    .replace(/^>\s+(.+)$/gm, '<blockquote>$1</blockquote>')
    .replace(/^-\s+(.+)$/gm, '<li>$1</li>')
    .replace(/(<li>.*<\/li>)/gs, '<ul>$1</ul>')
    .replace(/\n\n/g, '</p><p>')
    .replace(/^(?!<[hbulia]|<block)(.+)$/gm, '<p>$1</p>')
    .replace(/<p><\/p>/g, '');
}
---

<Base
  tr={tr}
  title={post?.title ? `${post.title} — ${tr.metaTitle}` : tr.metaTitle}
  desc={post?.excerpt || tr.metaDesc}
  ogImage={post?.image || tr.ogImage}
  canonical={`https://laregularizacion.com/en/blog/${slug}`}
>
  {!post ? (
    <section class="py-16 bg-slate-50 min-h-screen">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="bg-white rounded-2xl border border-slate-200 p-8 text-center">
          <div class="text-4xl mb-3">🔍</div>
          <p class="font-body text-slate-500">Article not found or not available in English.</p>
          <a href="/en/blog/" class="inline-block mt-4 font-display text-sm font-semibold text-blue-700 hover:text-blue-800">
            ← Back to News
          </a>
        </div>
      </div>
    </section>
  ) : (
    <article class="py-16 bg-slate-50 min-h-screen">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        {/* Header */}
        <header class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            <a href="/en/blog/" class="font-display text-sm font-semibold text-blue-700 hover:text-blue-800 flex items-center gap-1">
              ← {tr.blog.backToBlog}
            </a>
            <span class="text-slate-300">•</span>
            <time class="font-mono text-xs text-slate-500">
              {tr.blog.publishedOn} {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>

          <h1 class="font-display text-3xl md:text-4xl font-bold text-slate-900 mb-4">
            {post.title}
          </h1>

          <p class="font-body text-lg text-slate-600 mb-6">
            {post.excerpt}
          </p>

          <div class="flex flex-wrap items-center gap-2">
            {post.category && (
              <span class="font-mono text-xs text-slate-500 bg-slate-100 px-2 py-1 rounded">
                {post.category}
              </span>
            )}
            {post.is_trending && (
              <span class="font-mono text-xs text-amber-700 bg-amber-100 px-2 py-1 rounded">
                {tr.blog.trendingTag}
              </span>
            )}
            {post.primary_keyword && (
              <span class="font-mono text-xs text-blue-700 bg-blue-50 px-2 py-1 rounded">
                {post.primary_keyword}
              </span>
            )}
          </div>
        </header>

        {/* Hero Image */}
        {post.image && (
          <div class="mb-10 rounded-2xl overflow-hidden">
            <img
              src={post.image}
              alt={post.title}
              class="w-full h-auto max-h-[400px] object-cover"
              loading="eager"
            />
          </div>
        )}

        {/* Content */}
        <div class="prose prose-slate max-w-none font-body text-slate-700 mb-12">
          <div set:html={renderMd(post.body)} />
        </div>

        {/* Sources */}
        {post.sources && post.sources.length > 0 && (
          <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 mb-10">
            <h3 class="font-display font-bold text-blue-900 mb-3">{tr.blog.sourceLabel}</h3>
            <ul class="space-y-2">
              {post.sources.map((src: string, i: number) => (
                <li class="font-mono text-sm">
                  <a href={src} target="_blank" rel="noopener" class="text-blue-700 hover:text-blue-800 hover:underline">
                    {src}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* Footer note */}
        <div class="border-t border-slate-200 pt-6">
          <p class="font-body text-sm text-slate-500 italic">
            {tr.blog.autoUpdated}
          </p>
        </div>
      </div>
    </article>
  )}
</Base>