---
import Base from "../../layouts/Base.astro";;
import { translations } from "../../data/translations";;

const tr = translations.en;
---

<Base tr={tr} title="Privacy Policy" desc="Privacy Policy of LaRegularizacion.com - How we protect your data">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-3xl font-bold mb-8">Privacy Policy</h1>
    
    <div class="prose prose-lg max-w-none">
      <p class="text-gray-600 mb-6">Last updated: April 20, 2026</p>
      
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">1. Information We Collect</h2>
        <p>At LaRegularizacion.com, we respect your privacy. We collect:</p>
        <ul class="list-disc pl-6 mb-4">
          <li><strong>Usage information:</strong> Pages visited, time on site, referrals</li>
          <li><strong>Technical data:</strong> Browser, device, IP address (anonymized)</li>
          <li><strong>Cookies:</strong> For analytics and personalization (see Cookies section)</li>
          <li><strong>Forms:</strong> If you contact us via email or forms</li>
        </ul>
      </section>
      
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">2. How We Use Your Information</h2>
        <ul class="list-disc pl-6 mb-4">
          <li>Improve site content and user experience</li>
          <li>Analyze traffic and trends (Google Analytics)</li>
          <li>Show relevant ads (Google AdSense)</li>
          <li>Respond to inquiries and comments</li>
        </ul>
      </section>
      
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">3. Cookies and Similar Technologies</h2>
        <p>We use cookies for:</p>
        <ul class="list-disc pl-6 mb-4">
          <li><strong>Analytics:</strong> Google Analytics to understand site usage</li>
          <li><strong>Advertising:</strong> Google AdSense to show relevant ads</li>
          <li><strong>Functionality:</strong> Remember language preferences</li>
        </ul>
        <p>You can disable cookies in your browser settings.</p>
      </section>
      
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">4. Google AdSense</h2>
        <p>We use Google AdSense to display ads. Google may use cookies to personalize ads based on your visits to this and other websites. You can opt out of personalized advertising by visiting <a href="https://www.google.com/settings/ads" class="text-blue-600 hover:underline">Google Ads Settings</a>.</p>
      </section>
      
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">5. Third Parties</h2>
        <p>We do not sell, trade, or transfer your personal information to third parties, except:</p>
        <ul class="list-disc pl-6 mb-4">
          <li>Service providers who help us operate the site (analytics, hosting)</li>
          <li>Compliance with laws or protection of rights</li>
        </ul>
      </section>
      
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">6. Security</h2>
        <p>We implement security measures to protect your information, but no internet transmission is 100% secure.</p>
      </section>
      
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">7. Your Rights</h2>
        <p>You have the right to:</p>
        <ul class="list-disc pl-6 mb-4">
          <li>Access your personal data</li>
          <li>Correct inaccurate information</li>
          <li>Request deletion of your data</li>
          <li>Object to processing of your data</li>
        </ul>
        <p>To exercise these rights, contact us at: <strong>contact@laregularizacion.com</strong></p>
      </section>
      
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">8. Changes to This Policy</h2>
        <p>We may update this policy periodically. We will notify you of significant changes by posting the new policy on this page.</p>
      </section>
      
      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">9. Contact</h2>
        <p>If you have questions about this privacy policy, contact us at:</p>
        <p class="mt-2"><strong>Email:</strong> contact@laregularizacion.com</p>
      </section>
    </div>
  </div>
</Base>