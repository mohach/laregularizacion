<script define:vars={{
  questions: tr.quiz.questions,
  resTitles: tr.quiz.resultTitles,
  resOk: tr.quiz.resultOk,
  stepOf: tr.quiz.stepOf,
  nSteps: tr.quiz.questions.length,
  cdEnded: tr.cd.ended,
  langCode: tr.lang,
}}>
// ── COUNTDOWN ──
const DEADLINE = new Date('2026-06-30T23:59:59').getTime();
const START    = new Date('2026-04-16T00:00:00').getTime();

function flip(id, val) {
  const el = document.getElementById(id);
  if (!el) return;
  const s = String(val).padStart(2,'0');
  if (el.textContent !== s) {
    el.classList.remove('flip'); void el.offsetWidth;
    el.classList.add('flip'); el.textContent = s;
  }
}

const urgMsg = {
  es: d => d <= 10 ? `⚠️ ¡Solo ${d} días!` : `Quedan ${d} días · Actúa ya`,
  en: d => d <= 10 ? `⚠️ ${d} days left!` : `${d} days remaining`,
  ar: d => d <= 10 ? `⚠️ ${d} أيام فقط!` : `تبقّى ${d} يوماً`,
  ur: d => d <= 10 ? `⚠️ صرف ${d} دن!` : `${d} دن باقی`,
};

function tick() {
  const now = Date.now(), diff = DEADLINE - now;
  if (diff <= 0) {
    ['d','h','m','s'].forEach(u => {
      ['cd-','cd-dt-'].forEach(pfx => { const e = document.getElementById(`${pfx}${u}`); if(e) e.textContent='00'; });
    });
    ['cd-msg','cd-dt-msg'].forEach(id => { const m = document.getElementById(id); if(m) m.textContent = cdEnded; });
    return;
  }
  const vals = {
    d: Math.floor(diff/86400000),
    h: Math.floor(diff%86400000/3600000),
    m: Math.floor(diff%3600000/60000),
    s: Math.floor(diff%60000/1000),
  };
  // Update both mobile and desktop countdown elements
  ['d','h','m','s'].forEach(u => {
    flip('cd-' + u, vals[u]);
    // Desktop: direct set (no flip animation needed, same value)
    const dt = document.getElementById('cd-dt-' + u);
    if(dt) { const s2 = String(vals[u]).padStart(2,'0'); if(dt.textContent !== s2) dt.textContent = s2; }
  });
  const pct = Math.min(100, Math.max(0, (now-START)/(DEADLINE-START)*100));
  ['cd-prog','cd-dt-prog'].forEach(id => { const p = document.getElementById(id); if(p) p.style.width = pct.toFixed(2)+'%'; });
  const dLeft = Math.ceil(diff/86400000);
  const msg = (urgMsg[langCode]||urgMsg.es)(dLeft);
  ['cd-msg','cd-dt-msg'].forEach(id => { const m = document.getElementById(id); if(m) m.textContent = msg; });
}
tick(); setInterval(tick, 1000);

// ── QUIZ ──
let step = 0;

function renderQuiz() {
  const s = questions[step];
  document.getElementById('qq').textContent = s.q;
  document.getElementById('qh').textContent = s.hint;
  document.getElementById('q-step').textContent = `${step+1} ${stepOf} ${nSteps}`;
  document.getElementById('q-prog').style.width = `${(step+1)/nSteps*100}%`;
  document.getElementById('q-result').className = 'hidden mt-4 rounded-xl p-4 text-center';
  const box = document.getElementById('q-opts');
  box.innerHTML = '';
  s.opts.forEach(opt => {
    const b = document.createElement('button');
    b.textContent = opt.label;
    // qbtn class gets RTL text-align from our CSS
    b.className = 'qbtn w-full px-3.5 py-2.5 rounded-xl border-2 border-slate-200 bg-white text-xs text-slate-700 hover:border-blue-400 hover:bg-blue-50 hover:text-blue-800 transition-all duration-150';
    b.onclick = () => {
      box.querySelectorAll('button').forEach(x => x.classList.remove('!border-green-500','!bg-green-50','!border-red-500','!bg-red-50'));
      b.classList.add(opt.fail ? '!border-red-500' : '!border-green-500', opt.fail ? '!bg-red-50' : '!bg-green-50');
      setTimeout(() => {
        if (opt.fail) showResult('fail', opt.fail);
        else if (opt.warn) showResult('warn', opt.warn);
        else if (step < questions.length-1) { step++; renderQuiz(); }
        else showResult('ok');
      }, 360);
    };
    box.appendChild(b);
  });
}

function showResult(type, msg='') {
  document.getElementById('q-opts').innerHTML='';
  document.getElementById('qq').textContent='';
  document.getElementById('qh').textContent='';
  const r = document.getElementById('q-result');
  const C = {
    ok:   { icon:'🎉', title:resTitles.ok,   body:resOk, cls:'mt-4 rounded-xl p-4 text-center bg-green-50 border-2 border-green-200' },
    fail: { icon:'⛔', title:resTitles.fail,  body:msg,   cls:'mt-4 rounded-xl p-4 text-center bg-red-50 border-2 border-red-200' },
    warn: { icon:'⚠️', title:resTitles.warn, body:msg,   cls:'mt-4 rounded-xl p-4 text-center bg-amber-50 border-2 border-amber-200' },
  };
  const c = C[type];
  r.className = c.cls;
  document.getElementById('qr-icon').textContent = c.icon;
  document.getElementById('qr-title').textContent = c.title;
  document.getElementById('qr-body').textContent = c.body;
}

document.getElementById('q-reset')?.addEventListener('click', () => { step=0; renderQuiz(); });
renderQuiz();

// ── SCROLL REVEAL ──
const obs = new IntersectionObserver(entries =>
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('in'); }),
  { threshold: 0.1 }
);
document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
