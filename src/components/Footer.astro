---
import type { Translation } from '../data/translations';

interface Props { tr: Translation }
const { tr } = Astro.props;
const isRTL = tr.dir === 'rtl';
---

<footer class="bg-slate-900 text-slate-300 mt-20 border-t-4 border-blue-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">

    <!-- Disclaimer -->
    <div class:list={[
      'rounded-2xl border border-amber-600/30 bg-amber-900/20 p-5 mb-10 text-sm leading-relaxed',
      isRTL ? 'text-right font-arabic' : 'text-left font-body'
    ]}>
      <span class="text-amber-400 font-bold">⚠️ </span>
      <span class="text-amber-200">{tr.footer.disclaimer}</span>
    </div>

    <!-- Footer grid -->
    <div class:list={['grid grid-cols-1 md:grid-cols-4 gap-8 mb-8', isRTL ? 'text-right md:grid-flow-col-dense' : '']}>

      <!-- Brand -->
      <div>
        <div class:list={['flex items-center gap-2.5 mb-3', isRTL ? 'flex-row-reverse justify-end' : '']}>
          <div class="w-7 h-7 rounded-lg bg-blue-700 flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414A1 1 0 0119 7.414V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <span class:list={['font-bold text-white text-base', isRTL ? 'font-arabic' : 'font-display']}>{tr.siteName}</span>
        </div>
        <p class:list={['text-xs text-slate-500 leading-relaxed', isRTL ? 'font-arabic' : 'font-mono']}>
          {tr.tagline}
        </p>
      </div>

      <!-- Official links -->
      <div>
        <h3 class:list={['font-mono text-xs text-slate-500 uppercase tracking-widest mb-3', isRTL ? 'font-arabic text-right' : '']}>
          {tr.footer.linksTitle}
        </h3>
        <ul class:list={['space-y-2', isRTL ? 'text-right' : '']}>
          {[
            { href: 'https://www.inclusion.gob.es/regularizacion', label: 'inclusion.gob.es/regularizacion' },
            { href: 'https://www.boe.es/boe/dias/2026/04/15/pdfs/BOE-A-2026-8284.pdf', label: 'BOE-A-2026-8284 (PDF)' },
            { href: 'tel:060', label: '📞 060' },
            { href: 'https://www.inclusion.gob.es/formulario-consultas-regularizacion-extraordinaria-2026', label: 'Formulario consultas' },
          ].map(l => (
            <li>
              <a href={l.href} target="_blank" rel="noopener"
                 class:list={['text-sm text-slate-400 hover:text-blue-400 transition-colors', isRTL ? 'font-arabic' : 'font-body']}
                 style="text-decoration:none">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class:list={['font-mono text-xs text-slate-500 uppercase tracking-widest mb-3', isRTL ? 'font-arabic text-right' : '']}>
          Legal
        </h3>
        <ul class:list={['space-y-2', isRTL ? 'text-right' : '']}>
          {[
            { 
              href: tr.lang === 'es' ? '/privacy' : `/${tr.lang}/privacy`,
              label: tr.lang === 'es' ? 'Política de Privacidad' : tr.lang === 'en' ? 'Privacy Policy' : tr.lang === 'ar' ? 'سياسة الخصوصية' : 'رازداری کی پالیسی'
            },
            { 
              href: tr.lang === 'es' ? '/terms' : `/${tr.lang}/terms`,
              label: tr.lang === 'es' ? 'Términos de Servicio' : tr.lang === 'en' ? 'Terms of Service' : tr.lang === 'ar' ? 'شروط الخدمة' : 'سروس کی شرائط'
            },
            { 
              href: tr.lang === 'es' ? '/disclaimer' : `/${tr.lang}/disclaimer`,
              label: tr.lang === 'es' ? 'Aviso Legal' : tr.lang === 'en' ? 'Legal Disclaimer' : tr.lang === 'ar' ? 'إخلاء المسؤولية' : 'قانونی ذمہ داری سے انکار'
            },
            { 
              href: tr.lang === 'es' ? '/about' : `/${tr.lang}/about`,
              label: tr.lang === 'es' ? 'Sobre Nosotros' : tr.lang === 'en' ? 'About Us' : tr.lang === 'ar' ? 'من نحن' : 'ہمارے بارے میں'
            },
            { 
              href: tr.lang === 'es' ? '/contact' : `/${tr.lang}/contact`,
              label: tr.lang === 'es' ? 'Contacto' : tr.lang === 'en' ? 'Contact' : tr.lang === 'ar' ? 'اتصل بنا' : 'رابطہ'
            },
          ].map(l => (
            <li>
              <a href={l.href}
                 class:list={['text-sm text-slate-400 hover:text-blue-400 transition-colors', isRTL ? 'font-arabic' : 'font-body']}
                 style="text-decoration:none">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Languages -->
      <div>
        <h3 class:list={['font-mono text-xs text-slate-500 uppercase tracking-widest mb-3', isRTL ? 'font-arabic text-right' : '']}>
          {tr.footer.langsTitle}
        </h3>
        <div class:list={['flex flex-wrap gap-2', isRTL ? 'justify-end' : '']}>
          {[
            { code: 'es', label: 'Español', href: '/' },
            { code: 'en', label: 'English', href: '/en/' },
            { code: 'ar', label: 'العربية', href: '/ar/' },
            { code: 'ur', label: 'اردو',    href: '/ur/' },
          ].map(l => (
            <a href={l.href}
               class:list={[
                 'px-3 py-1.5 rounded-lg text-xs font-medium transition-all',
                 tr.lang === l.code ? 'bg-blue-700 text-white' : 'bg-slate-800 text-slate-400 hover:bg-slate-700 hover:text-white'
               ]}
               style="text-decoration:none"
               hreflang={l.code}
            >{l.label}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-6 text-center">
      <p class:list={['text-xs text-slate-600 leading-relaxed', isRTL ? 'font-arabic' : 'font-body']}>
        {tr.footer.note}
      </p>
    </div>
  </div>
</footer>
