---
import type { Translation } from '../data/translations';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';
import matter from 'gray-matter';

interface Props { tr: Translation; limit?: number }
const { tr } = Astro.props;
const limit = Astro.props.limit ?? 6;
const R = tr.dir === 'rtl';
const bf = tr.lang === 'ar' ? 'font-arabic' : tr.lang === 'ur' ? 'font-urdu' : 'font-body';
const blogHref = tr.lang === 'es' ? '/blog' : `/${tr.lang}/blog`;

// Get most recent blog posts for this language
let recentPosts = [];
try {
  const blogDir = join(process.cwd(), 'src', 'content', 'blog');
  const files = await readdir(blogDir);
  
  for (const file of files.filter(f => f.endsWith('.mdx'))) {
    const raw = await readFile(join(blogDir, file), 'utf8');
    const { data } = matter(raw);
    
    let title = '';
    if (tr.lang === 'es') title = data.title_es || data.title_en || '';
    else if (tr.lang === 'en') title = data.title_en || data.title_es || '';
    else if (tr.lang === 'ar') title = data.title_ar || data.title_es || '';
    else if (tr.lang === 'ur') title = data.title_ur || data.title_es || '';
    
    if (title) {
      recentPosts.push({
        slug: file.replace('.mdx', ''),
        title: title,
        category: data.category || 'Noticias',
        is_trending: data.is_trending || false,
        date: data.date
      });
    }
  }
  
  recentPosts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
  recentPosts = recentPosts.slice(0, limit);
} catch (e) {
  console.log('Error loading blog posts:', e.message);
}
---

<div>
  <div class="flex items-center justify-between mb-6">
    <h2 class:list={['font-display text-xl font-bold text-slate-900 tracking-tight', bf]}>{tr.blog.title}</h2>
    <a href={blogHref}
       class:list={['text-xs font-semibold text-blue-700 hover:text-blue-900 transition-colors shrink-0', bf]}>
      {tr.blog.readMore}
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {recentPosts.map((post, index) => (
      <>
        <a href={tr.lang === 'es' ? `/blog/${post.slug}` : `/${tr.lang}/blog/${post.slug}`}
           class="bg-white border border-slate-100 rounded-xl p-4 hover:shadow-sm hover:border-slate-200 transition-all group"
           style="text-decoration:none;color:inherit">
          <div class="flex items-center gap-2 mb-2 flex-wrap">
            <span class:list={['font-mono text-xs bg-slate-100 text-slate-500 px-2 py-0.5 rounded-full', bf]}>{post.category}</span>
            {post.is_trending && <span class="font-mono text-xs bg-orange-100 text-orange-700 px-2 py-0.5 rounded-full">{tr.blog.trendingTag}</span>}
          </div>
          <h3 class:list={['font-display text-sm font-bold text-slate-800 group-hover:text-blue-700 transition-colors mb-2', bf]}>
            {post.title}
          </h3>
          <time class:list={['font-mono text-xs text-slate-400', bf]}>
            {new Date(post.date).toLocaleDateString(tr.lang === 'es' ? 'es-ES' : tr.lang === 'en' ? 'en-US' : tr.lang === 'ar' ? 'ar-EG' : 'ur-PK', { 
              year: 'numeric', 
              month: 'short', 
              day: 'numeric' 
            })}
          </time>
        </a>
        
        {/* Ad after 3rd post */}
        {index === 2 && (
          <div class="md:col-span-2 lg:col-span-3">
            <div class="text-center text-xs text-slate-400 mb-2">Publicidad</div>
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-2691466441263858"
                 data-ad-slot="2345678901"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script>
                 (adsbygoogle = window.adsbygoogle || []).push({});
            </script>
          </div>
        )}
      </>
    ))}

    {recentPosts.length === 0 && (
      <div class="col-span-3 bg-white border border-slate-100 rounded-xl p-6 text-center">
        <div class="text-3xl mb-2">🤖</div>
        <p class:list={['text-xs text-slate-400', bf]}>{tr.blog.noArticles}</p>
      </div>
    )}
  </div>
</div>
