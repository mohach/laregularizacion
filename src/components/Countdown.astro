---
import type { Translation } from '../data/translations';

interface Props { tr: Translation; prefix?: string }
const { tr } = Astro.props;
const prefix = Astro.props.prefix ?? 'cd';
const R = tr.dir === 'rtl';
const bf = tr.lang === 'ar' ? 'font-arabic' : tr.lang === 'ur' ? 'font-urdu' : 'font-body';
---

<section class="bg-gradient-to-br from-slate-900 via-blue-900 to-blue-700 text-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 sm:py-12">
    <div style="display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap;"
         class={`mb-1 ${R ? 'flex-row-reverse' : ''}`}>
      <span class:list={['font-mono text-xs text-blue-200 uppercase tracking-widest', bf]}>{tr.cd.title}</span>
      <span class:list={['text-xs font-semibold text-amber-300', bf]}>{tr.cd.deadline}</span>
    </div>
    <div class="w-64 mx-auto mb-2">
      <div class="grid grid-cols-4 gap-1.5">
        {(['d','h','m','s'] as const).map((u,i) => (
          <div class="text-center">
            <div class="bg-black/20 rounded-xl py-2 mb-1">
              <span class="cd-num font-display font-bold text-2xl text-white leading-none" id={`${prefix}-${u}`}>--</span>
            </div>
            <span class:list={['font-mono text-xs text-white/45 uppercase tracking-wider block', bf]}>
              {[tr.cd.days, tr.cd.hours, tr.cd.mins, tr.cd.secs][i]}
            </span>
          </div>
        ))}
      </div>
      <div class="h-1 bg-white/10 rounded-full overflow-hidden mb-1.5">
        <div id={`${prefix}-prog`} class="h-full bg-gradient-to-r from-green-400 to-sky-400 rounded-full" style="width:0%"></div>
      </div>
    </div>
    <p class:list={['text-xs text-white/40 text-center', bf]} id={`${prefix}-msg`}></p>
  </div>
</section>

<script define:vars={{ langCode: tr.lang, cdEnded: tr.cd.ended, prefix }}>
// ── COUNTDOWN ──
const DEADLINE = new Date('2026-06-30T23:59:59').getTime();
const START    = new Date('2026-04-16T00:00:00').getTime();

function flip(id, val) {
  const el = document.getElementById(id);
  if (!el) return;
  const s = String(val).padStart(2,'0');
  if (el.textContent !== s) {
    el.classList.remove('flip'); void el.offsetWidth;
    el.classList.add('flip'); el.textContent = s;
  }
}

const urgMsg = {
  es: d => d <= 10 ? `⚠️ ¡Solo ${d} días!` : `Quedan ${d} días · Actúa ya`,
  en: d => d <= 10 ? `⚠️ ${d} days left!` : `${d} days remaining`,
  ar: d => d <= 10 ? `⚠️ ${d} أيام فقط!` : `تبقّى ${d} يوماً`,
  ur: d => d <= 10 ? `⚠️ صرف ${d} دن!` : `${d} دن باقی`,
};

function tick() {
  const now = Date.now(), diff = DEADLINE - now;
  if (diff <= 0) {
    ['d','h','m','s'].forEach(u => {
      const e = document.getElementById(`${prefix}-${u}`);
      if(e) e.textContent='00';
    });
    const m = document.getElementById(`${prefix}-msg`);
    if(m) m.textContent = cdEnded;
    return;
  }
  const vals = {
    d: Math.floor(diff/86400000),
    h: Math.floor(diff%86400000/3600000),
    m: Math.floor(diff%3600000/60000),
    s: Math.floor(diff%60000/1000),
  };
  ['d','h','m','s'].forEach(u => {
    flip(prefix + '-' + u, vals[u]);
  });
  const pct = Math.min(100, Math.max(0, (now-START)/(DEADLINE-START)*100));
  const p = document.getElementById(prefix + '-prog');
  if(p) p.style.width = pct.toFixed(2)+'%';
  const dLeft = Math.ceil(diff/86400000);
  const msg = (urgMsg[langCode]||urgMsg.es)(dLeft);
  const m = document.getElementById(prefix + '-msg');
  if(m) m.textContent = msg;
}
tick(); setInterval(tick, 1000);
</script>
